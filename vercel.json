{
  "redirects": [
    {
      "source": "/feed",
      "destination": "/feed.xml",
      "permanent": true
    },
    {
      "source": "/feed/feed.xml",
      "destination": "/feed.xml",
      "permanent": true
    },
    {
      "source": "/blog/life-before-social-media/",
      "destination": "/posts/life-before-social-media/",
      "permanent": true
    },
    {
      "source": "/blog/:slug",
      "destination": "/posts/:slug",
      "permanent": true
    }
  ]
}