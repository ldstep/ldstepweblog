{
  "redirects": [
    {
      "source": "/feed",
      "destination": "/feed.xml",
      "permanent": true
    },
    {
      "source": "/feed/feed.xml",
      "destination": "/feed.xml",
      "permanent": true
    },
    {
      "source": "/blog/life-before-social-media/",
      "destination": "https://ldstephens.net/posts/life-before-social-media/",
      "permanent": true
    },
    {
      "source": "/blog/:path*",
      "destination": "https://ldstephens.net/posts/:path*/",
      "permanent": true
    }
  ]
}